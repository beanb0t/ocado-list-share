{
  "manifest_version": 3,
  "name": "Ocado List Share",
  "version": "1.0.0",
  "description": "Share your Ocado shopping list or basket with anyone via a link",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["*://*.ocado.com/*", "https://is.gd/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.ocado.com/*"],
      "js": ["content/injector.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.ocado.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
